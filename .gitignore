# ═══════════════════════════════════════════════════════════════
# .gitignore — Node.js Web App
# Covers: Linux, macOS, Windows contributors
#         VS Code, JetBrains, Vim, Emacs, Sublime, Nano
# ═══════════════════════════════════════════════════════════════


# ── Logs ─────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Diagnostic reports ───────────────────────────────────────────
# https://nodejs.org/api/report.html
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ── Runtime data ─────────────────────────────────────────────────
pids
*.pid
*.seed
*.pid.lock

# ── Coverage ─────────────────────────────────────────────────────
lib-cov
coverage
*.lcov
.nyc_output

# ── Dependency directories ───────────────────────────────────────
node_modules/
jspm_packages/
web_modules/
bower_components/

# ── Build output ─────────────────────────────────────────────────
build/Release
dist/
out/
.output/

# ── Framework caches & build output ──────────────────────────────
# Next.js
.next/

# Nuxt.js
.nuxt/

# Gatsby
.cache/

# VuePress
.vuepress/dist
.temp/

# VitePress
**/.vitepress/dist
**/.vitepress/cache

# SvelteKit
.svelte-kit/

# Docusaurus
.docusaurus/

# Parcel
.parcel-cache/

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

# ── Package manager caches & artifacts ───────────────────────────
# npm
.npm
*.tgz

# pnpm
.pnpm-store/

# Yarn v1
.yarn-integrity

# Yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ── TypeScript ───────────────────────────────────────────────────
*.tsbuildinfo

# ── Linting & formatting caches ──────────────────────────────────
.eslintcache
.stylelintcache
.grunt
.lock-wscript

# ── Misc tooling ─────────────────────────────────────────────────
.node_repl_history
.tern-port
.fusebox/
.serverless/
.dynamodb/
.firebase/
.vscode-test/

# ── Environment & secrets ─────────────────────────────────────────
.env
.env.*
!.env.example
.npmrc
.yarnrc
.yarnrc.yml
.envrc

# ── Database files ───────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ── Patch files ───────────────────────────────────────────────────
*.patch
!.yarn/patches/

# ── Version managers ─────────────────────────────────────────────
.tool-versions
.mise.toml
.direnv/

# ══════════════════════════════════════════════════════════════════
# OS
# ══════════════════════════════════════════════════════════════════

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# Linux
.directory
.Trash-*
*~
.nfs*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# ══════════════════════════════════════════════════════════════════
# Editors & IDEs
# ══════════════════════════════════════════════════════════════════

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*.un~
Session.vim
.netrwhist

# Emacs
\#*\#
.\#*
.dir-locals.el

# Sublime Text
*.sublime-project
*.sublime-workspace

# Nano
*.save

# ── Misc ────────────────────────────────────────────────────────
*.tmp
*.temp
